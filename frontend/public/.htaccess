Options -Indexes

# index.html nigdy nie cachować (React SPA - zawsze świeży)
<FilesMatch "index\.html$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
  Header set Expires "0"
</FilesMatch>

RewriteEngine On
RewriteBase /

# WordPress - admin, login, API, pliki systemowe
RewriteRule ^wp-admin(/.*)?$ - [L]
RewriteRule ^wp-login\.php$ - [L]
RewriteRule ^wp-cron\.php$ - [L]
RewriteRule ^wp-json(/.*)?$ - [L]
RewriteRule ^wp-content(/.*)?$ - [L]
RewriteRule ^wp-includes(/.*)?$ - [L]
RewriteRule ^xmlrpc\.php$ - [L]

# Istniejące pliki i katalogi serwuj bezpośrednio (pliki React, obrazki itp.)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Wszystko inne → React SPA
RewriteRule ^ index.html [L]
